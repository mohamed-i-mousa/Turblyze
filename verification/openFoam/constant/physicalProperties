viscosityModel  constant;

// Air at 15 C
// rho = 1.225 kg/m^3
// mu  = 1.7894e-5 Pa.s
// nu  = mu/rho = 1.461e-5 m^2/s

nu              [0 2 -1 0 0 0 0] 1.461e-5;

