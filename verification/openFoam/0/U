FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 -20.0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;
    }

    sphere
    {
        type            noSlip;
    }

    wall1
    {
        type            noSlip;
    }

    wall2
    {
        type            noSlip;
    }

    wall3
    {
        type            noSlip;
    }

    wall4
    {
        type            noSlip;
    }
}

